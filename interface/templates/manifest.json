        {
          "src": "/static/icons/face-192x192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Fingerprint Scan",
      "short_name": "Fingerprint",
      "description": "Start fingerprint scan authentication",
      "url": "/authenticate/fingerprint",
      "icons": [
        {
          "src": "/static/icons/fingerprint-192x192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "One-Time Password",
      "short_name": "OTP",
      "description": "Start OTP authentication",
      "url": "/authenticate/otp",
      "icons": [
        {
          "src": "/static/icons/otp-192x192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
